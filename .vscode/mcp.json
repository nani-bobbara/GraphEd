{
	"servers": {
		"mcp-github": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.1.2"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.1.2"
		},
		"mcp-supabase": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--project-ref",
				"${input:project-ref}",
				"--read-only",
				"${input:read-only}",
				"--features",
				"${input:features}",
				"--api-url",
				"${input:api-url}",
				"--registry",
				"https://registry.npmjs.org",
				"@supabase/mcp-server-supabase@0.8.1"
			],
			"env": {
				"SUPABASE_ACCESS_TOKEN": "${input:SUPABASE_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.8.1"
		},
		"mcp-stripe": {
			"type": "http",
			"url": "https://mcp.stripe.com",
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.4"
		},
		"mcp-vercel": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		},
		"mcp-localfs": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"${input:workspace-root}"
			],
			"version": "latest"
		},
		"mcp-shell": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-shell"
			],
			"env": {
				"SHELL_MCP_MODE": "restricted",
				"SHELL_MCP_ALLOWED_COMMANDS": "npm run lint,npm run type-check,npm test,npm run build,supabase db lint,supabase db push,supabase functions deploy"
			},
			"version": "latest"
		},
		"com.supabase/mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"--project-ref",
				"${input:project-ref}",
				"--read-only",
				"${input:read-only}",
				"--features",
				"${input:features}",
				"--api-url",
				"${input:api-url}",
				"--registry",
				"https://registry.npmjs.org",
				"@supabase/mcp-server-supabase@0.8.1"
			],
			"env": {
				"SUPABASE_ACCESS_TOKEN": "${input:SUPABASE_ACCESS_TOKEN}"
			},
			"gallery": "https://api.mcp.github.com",
			"version": "0.8.1"
		},
		"io.github.github/github-mcp-server": {
			"type": "stdio",
			"command": "docker",
			"args": [
				"run",
				"-i",
				"--rm",
				"-e",
				"GITHUB_PERSONAL_ACCESS_TOKEN=${input:token}",
				"ghcr.io/github/github-mcp-server:1.1.2"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "1.1.2"
		},
		"com.stripe/mcp": {
			"type": "http",
			"url": "https://mcp.stripe.com",
			"gallery": "https://api.mcp.github.com",
			"version": "0.2.4"
		},
		"io.github.vercel/next-devtools-mcp": {
			"type": "stdio",
			"command": "npx",
			"args": [
				"next-devtools-mcp@0.3.6"
			],
			"gallery": "https://api.mcp.github.com",
			"version": "0.3.6"
		}
	},
	"policies": {
		"mcp-shell": {
			"permission": "restricted",
			"allowedAgents": [
				"backend",
				"frontend",
				"devops",
				"infra",
				"qa",
				"security-engineer",
				"ai-orchestrator"
			]
		},
		"mcp-localfs": {
			"permission": "scoped",
			"root": "${input:workspace-root}"
		},
		"mcp-stripe": {
			"permission": "finance-only",
			"allowedAgents": [
				"finance",
				"product-owner"
			]
		}
	},
	"inputs": [
		{
			"id": "workspace-root",
			"type": "promptString",
			"description": "Workspace root path for local filesystem MCP",
			"password": false,
			"default": "/workspaces/GraphEd"
		},
		{
			"id": "project-ref",
			"type": "promptString",
			"description": "Supabase project reference ID",
			"password": false
		},
		{
			"id": "read-only",
			"type": "promptString",
			"description": "Enable read-only mode",
			"password": false
		},
		{
			"id": "features",
			"type": "promptString",
			"description": "Comma-separated list of features to enable",
			"password": false
		},
		{
			"id": "api-url",
			"type": "promptString",
			"description": "Custom API URL",
			"password": false
		},
		{
			"id": "SUPABASE_ACCESS_TOKEN",
			"type": "promptString",
			"description": "Personal access token for Supabase API",
			"password": true
		},
		{
			"id": "token",
			"type": "promptString",
			"description": "",
			"password": true
		}
	]
}