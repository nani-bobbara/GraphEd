{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://graphed.local/schemas/command-contract.schema.json",
  "title": "Claude Command Contract",
  "type": "object",
  "required": [
    "name",
    "version",
    "input",
    "output",
    "triggeredAgents",
    "preconditions",
    "routingGuards"
  ],
  "properties": {
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "input": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "output": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "triggeredAgents": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "preconditions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    },
    "routingGuards": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
