{
  "$schema": "./command-contract.schema.json",
  "version": "1.0.0",
  "commands": [
    {"name":"bootstrap-repo.md","version":"1.0.0","input":["target environment","supabase project ref","vercel project id"],"output":["bootstrap readiness summary"],"triggeredAgents":["Backend Agent","Security Engineer Agent","Architect Agent"],"preconditions":[".env.example exists","openapi.yaml exists"],"routingGuards":["missing SUPABASE_ACCESS_TOKEN blocks","type-check failure blocks"]},
    {"name":"create-feature.md","version":"1.0.0","input":["feature id","title","epic","acceptance criteria"],"output":["feature file","board update request"],"triggeredAgents":["Product Owner Agent","Architect Agent"],"preconditions":["epic exists"],"routingGuards":["duplicate id blocks"]},
    {"name":"create-user-story.md","version":"1.0.0","input":["user story id","title","feature id"],"output":["user story file"],"triggeredAgents":["Product Owner Agent","QA Agent"],"preconditions":["feature exists"],"routingGuards":["missing acceptance criteria blocks"]},
    {"name":"update-board.md","version":"1.0.0","input":["item id","source status","target status"],"output":["updated board"],"triggeredAgents":["Product Owner Agent"],"preconditions":["valid workflow transition"],"routingGuards":["dependency violation blocks"]},
    {"name":"update-roadmap.md","version":"1.0.0","input":["roadmap section","proposed change"],"output":["updated roadmap"],"triggeredAgents":["Product Owner Agent","Architect Agent"],"preconditions":["impact documented"],"routingGuards":["scope expansion without approval blocks"]},
    {"name":"validate-mcp-readiness.md","version":"1.0.0","input":["task id","required server list","requested capability set"],"output":["readiness matrix","allow deny decision"],"triggeredAgents":["AI Orchestrator Agent","Product Owner Agent"],"preconditions":["linked task exists"],"routingGuards":["missing server denies execution"]},
    {"name":"validate-agent-skill-fit.md","version":"1.0.0","input":["agent name","task capability requirements"],"output":["fit score","assignment allow deny"],"triggeredAgents":["AI Orchestrator Agent","Product Owner Agent"],"preconditions":["agent profile exists"],"routingGuards":["missing required skill blocks assignment"]},
    {"name":"generate-api.md","version":"1.0.0","input":["endpoint path","method","request schema","response schema"],"output":["api handler"],"triggeredAgents":["Backend Agent","Architect Agent","Security Engineer Agent"],"preconditions":["feature in progress"],"routingGuards":["contract drift blocks"]},
    {"name":"generate-module.md","version":"1.0.0","input":["module name","responsibilities"],"output":["module design"],"triggeredAgents":["Architect Agent","Backend Agent"],"preconditions":["feature eligible"],"routingGuards":["dependency unmet blocks"]},
    {"name":"generate-job.md","version":"1.0.0","input":["job name","trigger event"],"output":["job handler"],"triggeredAgents":["Backend Agent","Curation Agent"],"preconditions":["phase ownership defined"],"routingGuards":["phase conflict blocks"]},
    {"name":"validate-ai-output.md","version":"1.0.0","input":["json output","schema type"],"output":["validation result"],"triggeredAgents":["AI Orchestrator Agent","QA Agent"],"preconditions":["schema exists"],"routingGuards":["schema missing blocks"]},
    {"name":"generate-syllabus.md","version":"1.0.0","input":["topic id","constraints"],"output":["syllabus json"],"triggeredAgents":["AI Orchestrator Agent","Content Agent"],"preconditions":["pending_syllabus status"],"routingGuards":["validation failure blocks"]},
    {"name":"ingest-youtube.md","version":"1.0.0","input":["topic id","module ids","query set"],"output":["video metadata"],"triggeredAgents":["Ingestion Agent","Backend Agent"],"preconditions":["syllabus_ready status"],"routingGuards":["quota exhausted blocks"]},
    {"name":"rank-videos.md","version":"1.0.0","input":["topic id","candidate set"],"output":["ranked list"],"triggeredAgents":["Ranking Agent","Evaluation Agent"],"preconditions":["candidates exist"],"routingGuards":["evidence missing blocks"]},
    {"name":"generate-mindmap.md","version":"1.0.0","input":["topic id","graph inputs"],"output":["mindmap json"],"triggeredAgents":["Mindmap Agent","Frontend Agent"],"preconditions":["verified status"],"routingGuards":["invalid graph blocks"]},
    {"name":"run-tests.md","version":"1.0.0","input":["scope","linked item id"],"output":["test report"],"triggeredAgents":["QA Agent","Backend Agent"],"preconditions":["ready for qa or override"],"routingGuards":["undefined scope blocks"]},
    {"name":"file-bug.md","version":"1.0.0","input":["bug id","severity","linked item"],"output":["bug artifact"],"triggeredAgents":["QA Agent","Security Engineer Agent"],"preconditions":["repro evidence exists"],"routingGuards":["missing severity blocks"]},
    {"name":"security-scan.md","version":"1.0.0","input":["pr id","feature id"],"output":["security report","gate status"],"triggeredAgents":["Security Engineer Agent","QA Agent"],"preconditions":["pr diff exists"],"routingGuards":["high severity findings fail gate"]},
    {"name":"validate-rls.md","version":"1.0.0","input":["schema scope","migration id"],"output":["rls validation report"],"triggeredAgents":["Security Engineer Agent","Infra Agent"],"preconditions":["migration artifacts exist"],"routingGuards":["missing rls fails validation"]},
    {"name":"setup-supabase-env.md","version":"1.0.0","input":["target env","project ref","required variables"],"output":["supabase readiness report"],"triggeredAgents":["Backend Agent","Security Engineer Agent","Product Owner Agent"],"preconditions":["approved environment"],"routingGuards":["missing secrets blocks"]},
    {"name":"setup-vercel-env.md","version":"1.0.0","input":["target env","org id","project id","required variables"],"output":["vercel readiness report"],"triggeredAgents":["Frontend Agent","Security Engineer Agent","Product Owner Agent"],"preconditions":["approved environment"],"routingGuards":["missing secrets blocks"]}
  ]
}
