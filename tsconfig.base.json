{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "baseUrl": ".",
    "paths": {
      "@graphed/ui": ["./packages/ui/src/index.ts"],
      "@graphed/config": ["./packages/config/src/index.ts"],
      "@graphed/supabase-types": ["./packages/supabase-types/src/index.ts"]
    }
  },
  "exclude": ["node_modules"]
}
